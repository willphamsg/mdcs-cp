{
  "name": "lta-btds-gui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:dummy": "ng serve --configuration=dummy",
    "build": "ng build",
    "build:dummy": "ng build --configuration=dummy",
    "build:uat": "ng build --aot --output-hashing=all --configuration=uat",
    "watch": "ng build --watch --configuration development",
    "test": "CHROME_BIN=$(which chromium-browser || which chromium || which google-chrome || echo chrome) ng test",
    "test:coverage": "CHROME_BIN=$(which chromium-browser || which chromium || which google-chrome || echo chrome) ng test --watch=false --code-coverage",
    "test:coverage:ci": "CHROME_BIN=$(which google-chrome || which google-chrome-stable || which chromium-browser || which chromium || echo chrome) ng test --watch=false --code-coverage --progress=false --browsers=ChromeHeadlessCI",
    "serve:ssr:lta-btds-gui": "node dist/lta-btds-gui/server/server.mjs",
    "lint": "ng lint",
    "server:mdcs": "nodemon node/mdcs/index.js",
    "server:dagw": "nodemon node/dagw/index.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.13",
    "@angular/cdk": "^21.2.11",
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/material": "^21.2.11",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-browser-dynamic": "^21.2.13",
    "@angular/platform-server": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@angular/ssr": "^21.2.11",
    "@ngrx/signals": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@stomp/stompjs": "^7.3.0",
    "ag-grid-angular": "^34.3.1",
    "ag-grid-community": "^34.3.1",
    "angular-oauth2-oidc": "^17.0.2",
    "chart.js": "^4.5.1",
    "ng2-charts": "^6.0.1",
    "ngx-cookie-service": "^21.3.1",
    "ngx-mat-timepicker": "^21.0.1",
    "office-addin-dev-certs": "^1.13.5",
    "rxjs": "~7.8.2",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.8.1",
    "typeface-inter": "^3.18.1",
    "uuid": "^11.1.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.4.0",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/schematics": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@ngrx/eslint-plugin": "^21.1.0",
    "@types/express": "^4.17.25",
    "@types/jasmine": "~5.1.15",
    "@types/node": "^18.19.130",
    "@types/sockjs-client": "^1.5.4",
    "@typescript-eslint/eslint-plugin": "7.2.0",
    "@typescript-eslint/parser": "7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "browser-sync": "^3.0.4",
    "cors": "^2.8.6",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "^4.22.2",
    "jasmine-core": "~5.1.2",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nodemon": "^3.1.14",
    "prettier": "3.2.5",
    "prettier-eslint": "^16.4.2",
    "sass": "^1.99.0",
    "typescript": "~5.9.3"
  }
}
